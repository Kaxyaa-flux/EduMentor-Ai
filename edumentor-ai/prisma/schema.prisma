generator client {
  provider        = "prisma-client-js"
  engineType      = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  avatarUrl  String?
  groqApiKey String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  preferences      UserPreference?
  conversations    Conversation[]
  quizzes          Quiz[]
  quizResults      QuizResult[]
  progress         Progress[]
  learningAnalytics LearningAnalytics?
  apiUsage         ApiUsage[]
  mistakePatterns  MistakePattern[]
  dailyCompletions DailyCompletion[]
}

model UserPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  learningTopic     String   @default("Python")
  skillLevel        String
  learningGoal      String?
  dailyStudyMinutes Int?
  createdAt         DateTime @default(now())
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  createdAt      DateTime     @default(now())
}

model Quiz {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic       String
  difficulty  String
  quizData    Json
  createdAt   DateTime     @default(now())
  results     QuizResult[]
}

model QuizResult {
  id             String   @id @default(cuid())
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score          Int
  totalQuestions Int
  percentage     Float
  submittedAt    DateTime @default(now())
}

model Progress {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic              String
  masteryScore       Float    @default(0)
  quizzesCompleted   Int      @default(0)
  averageScore       Float    @default(0)
  updatedAt          DateTime @updatedAt

  @@unique([userId, topic])
}

model LearningAnalytics {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalSessions        Int      @default(0)
  totalMessages        Int      @default(0)
  totalQuizzes         Int      @default(0)
  averageQuizScore     Float    @default(0)
  totalLearningMinutes Int      @default(0)
  updatedAt            DateTime @updatedAt
}

model ApiUsage {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageDate        DateTime @db.Date
  chatRequests     Int      @default(0)
  quizGenerations  Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([userId, usageDate])
}

model KnowledgeChunk {
  id        String   @id @default(cuid())
  topic     String
  title     String
  content   String
  // PostgreSQL supports pgvector, but we'll stick to string for now to avoid needing the pgvector extension unless required
  embedding String?
  createdAt DateTime @default(now())
}

model MistakePattern {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language    String
  concept     String
  description String
  occurrences Int      @default(1)
  lastSeen    DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([userId, language, concept])
}

model DailyChallenge {
  id          String   @id @default(cuid())
  language    String
  date        String
  title       String
  description String
  starterCode String
  difficulty  String
  hints       String
  solution    String
  createdAt   DateTime @default(now())

  completions DailyCompletion[]

  @@unique([language, date])
}

model DailyCompletion {
  id               String         @id @default(cuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyChallengeId String
  dailyChallenge   DailyChallenge @relation(fields: [dailyChallengeId], references: [id], onDelete: Cascade)
  completedAt      DateTime       @default(now())

  @@unique([userId, dailyChallengeId])
}
